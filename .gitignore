# 依赖包（绝对不能传，太大了）
client/node_modules/
server/node_modules/

# 环境变量（包含密钥、数据库密码，绝对绝对要保密！）
*.env
*.env.local
*.env.production

# 上传的临时文件（PDF、录音等）
uploads/
pcm_cache/

# 日志文件
*.log
npm-debug.log*

# 操作系统临时文件
.DS_Store
Thumbs.db

# IDE 配置（看个人习惯，可以传也可以不传）
.vscode/
.idea/

# 打包后的文件
dist/
build/
*.tsbuildinfo